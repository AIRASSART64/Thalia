{% extends 'base.html.twig' %}

{% block body %}
<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12 sm:px-6 lg:px-8">
    <div class="max-w-md w-full space-y-8 bg-white p-8 rounded-2xl border border-gray-100 shadow-sm text-center">
        
      
        <div class="mx-auto flex items-center justify-center h-16 w-16 rounded-full bg-emerald-50 text-emerald-500">
            <i class="fa-solid fa-circle-check text-3xl"></i>
        </div>

        <div class="space-y-2">
            <h2 class="text-2xl font-bold text-gray-900">Spectacle enregistré !</h2>
            <p class="text-sm text-gray-500">
                Le spectacle <span class="font-semibold text-gray-800">"{{ show.title }}"</span> a été créé avec succès.
            </p>
        </div>

        <div class="border-t border-b border-gray-100 py-6 my-6 text-left">
            <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2">Prochaine étape (Optionnelle)</h3>
            <p class="text-xs text-gray-500 leading-relaxed">
                Vous pouvez maintenant associer des contacts (chargés de diffusion, régisseurs, artistes...) spécifiquement à ce spectacle.
            </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3">
           
            <a href="{{ path('show_show', {'id': show.id}) }}" 
               class="w-full sm:w-1/2 inline-flex justify-center items-center px-4 py-2.5 border border-gray-200 rounded-xl text-xs font-semibold text-gray-500 hover:bg-gray-50 transition">
                Pas maintenant
            </a>
            
       
            <a href="{{ path('contact_new', {'show_id': show.id}) }}" 
               class="w-full sm:w-1/2 inline-flex justify-center items-center px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold rounded-xl transition shadow-sm gap-2">
                <i class="fa-solid fa-plus text-[10px]"></i> Ajouter un contact
            </a>
        </div>
    </div>
</div>
{% endblock %}