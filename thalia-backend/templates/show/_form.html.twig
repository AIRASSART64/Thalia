{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-6 space-y-6">
    
    <h2 class="text-sm font-bold text-gray-900 border-b border-gray-150 pb-3 uppercase tracking-wider">
        Saisie manuelle des informations
    </h2>

    {# ─── BLOC 1 : INFO SPECTACLE (Responsive Grid) ─── #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div>
            {{ form_label(form.title, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.title, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.title) }}
        </div>
        <div>
            {{ form_label(form.duration_min, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.duration_min, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.duration_min) }}
        </div>
        <div>
            {{ form_label(form.discipline, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.discipline, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.discipline) }}
        </div>
    </div>

    {# ─── BLOC 1B : SYNOPSIS ─── #}
    <div class="border-t border-gray-50 pt-4">
        {{ form_label(form.synopsis, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
        {{ form_widget(form.synopsis, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800', 'rows': '3'}}) }}
        {{ form_errors(form.synopsis) }}
    </div>

    {# ─── BLOC 2 : URL DE L'AFFICHE SÉCURISÉE ─── #}
    <div class="border-t border-gray-50 pt-4">
        {{ form_label(form.artworkUrl, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-200">
            {% if show is defined and show.artworkUrl %}
                <div class="w-16 h-20 rounded-lg overflow-hidden bg-gray-200 shrink-0 border border-gray-100 shadow-sm mx-auto sm:mx-0">
                    <img src="{{ show.artworkUrl }}" class="w-full h-full object-cover" alt="Affiche actuelle">
                </div>
            {% else %}
                <div class="w-16 h-20 rounded-lg bg-gray-200 flex items-center justify-center shrink-0 text-gray-400 mx-auto sm:mx-0">
                    <i class="fa-regular fa-image text-xl"></i>
                </div>
            {% endif %}
            
            <div class="flex-grow w-full">
                {{ form_widget(form.artworkUrl, {'attr': {'class': 'w-full bg-white border border-gray-200 rounded-xl px-3 py-2 text-xs focus:border-indigo-500 outline-none text-gray-800'}}) }}
                <p class="text-[11px] text-gray-400 mt-1">Collez l'URL d'une image web (ex: hébergée sur votre site ou un cloud).</p>
            </div>
        </div>
        {{ form_errors(form.artworkUrl) }}
    </div>

    {# ─── BLOC 3 : TECHNIQUE (Dimensions Scène) ─── #}
    <div class="border-t border-gray-50 pt-4 space-y-4">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Fiche technique minimale</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
                {{ form_label(form.min_stage_width, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                {{ form_widget(form.min_stage_width, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                {{ form_errors(form.min_stage_width) }}
            </div>
            <div>
                {{ form_label(form.min_stage_depth, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                {{ form_widget(form.min_stage_depth, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                {{ form_errors(form.min_stage_depth) }}
            </div>
            <div>
                {{ form_label(form.min_stage_height, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                {{ form_widget(form.min_stage_height, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                {{ form_errors(form.min_stage_height) }}
            </div>
        </div>
    </div>

    {# ─── BLOC 4 : CRM & CONTACTS MULTI-TENANT ─── #}
    <div class="border-t border-gray-50 pt-4 grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            {{ form_label(form.pipeline_status, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.pipeline_status, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.pipeline_status) }}
        </div>
        <div>
            {{ form_label(form.contacts, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.contacts, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800 min-h-[42px]'}}) }}
            {{ form_errors(form.contacts) }}
        </div>
    </div>

    {# ─── BLOC 5 : ACTION SUBMIT RESPONSIVE ─── #}
    <div class="border-t border-gray-50 pt-4 flex flex-col-reverse sm:flex-row justify-between items-center gap-4">
        <a href="{{ path('show_index') }}" class="w-full sm:w-auto text-center text-xs font-semibold text-gray-500 hover:text-gray-700 transition py-2">
            Annuler
        </a>
        <button type="submit" class="w-full sm:w-auto justify-center bg-slate-900 text-white text-xs font-bold px-5 py-2.5 rounded-xl hover:bg-slate-800 transition shadow-sm inline-flex items-center gap-2">
            {{ button_label|default('Enregistrer') }} <i class="fa-solid fa-arrow-right text-[10px]"></i>
        </button>
    </div>

</div>

{{ form_rest(form) }}
{{ form_end(form) }}