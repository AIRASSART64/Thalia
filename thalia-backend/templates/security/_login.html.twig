<div class="relative bg-white border border-slate-100 shadow-2xl rounded-2xl p-6 sm:p-8 space-y-6 w-full max-w-md font-sans">
    
    {# En-tête du formulaire #}
    <div class="space-y-1.5">
        <h2 class="text-xl font-bold text-slate-900 tracking-tight">Connexion à votre espace</h2>
        <p class="text-xs text-slate-400">Saisissez vos identifiants pour accéder à votre tenant Thalia.</p>
    </div>

    {# Gestion des erreurs de sécurité Symfony (Style pastel épuré) #}
    {% if error ?? false %}
        <div class="bg-rose-50 text-rose-700 text-xs p-3 rounded-xl border border-rose-100 font-medium">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    {# Formulaire #}
    <form action="{{ path('app_login') }}" method="post" class="space-y-4">
        
        {# Champ Email #}
        <div>
            <label for="username" class="block text-xs font-bold text-slate-700 mb-1">Adresse e-mail professionnelle</label>
            <input type="email" 
                   value="{{ last_username ?? '' }}" 
                   name="email" 
                   id="username" 
                   class="w-full px-3 py-2 bg-slate-50/50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 transition placeholder-slate-300" 
                   placeholder="nom@institution.fr"
                   autocomplete="email" 
                   required 
                   autofocus>
        </div>

  
        <div>
            <div class="flex items-center justify-between mb-1">
                <label for="password" class="block text-xs font-bold text-slate-700">Mot de passe</label>
                {# Petit ajout discret présent en fond de ta maquette #}
                <a href="{{ path('app_forgot_password_request') }}" class="text-[11px] text-blue-500 hover:underline font-medium">Mot de passe oublié ?</a>
            </div>
            <input type="password" 
                   name="password" 
                   id="password" 
                   class="w-full px-3 py-2 bg-slate-50/50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 transition" 
                   placeholder="••••••••"
                   autocomplete="current-password" 
                   required>
        </div>

        {# Protection CSRF #}
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        {# Bouton Soumettre (Bleu azur vif harmonisé avec le profil et l'inscription) #}
        <div class="pt-1">
            <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2.5 rounded-xl text-sm transition shadow-sm shadow-blue-100">
                Se connecter
            </button>
        </div>

        {# Lien d'inscription #}
        <div class="text-center pt-2">
            <p class="text-xs text-slate-400">
                Pas encore de compte ? 
                <a href="{{ path('register') }}" class="text-blue-500 font-semibold hover:underline">Créer un compte</a>
            </p>
        </div>
    </form>
</div>