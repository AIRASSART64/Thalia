{% extends 'base.html.twig' %}

{% block title %}Modifier l'équipement{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto px-4 py-8">
    
    {# En-tête avec bouton retour et bouton supprimer #}
    <div class="mb-6 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <div class="flex items-center gap-2 text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">
                <a href="{{ path('equipment_index') }}" class="hover:text-gray-600 transition">Équipements</a>
                <i class="fa-solid fa-chevron-right text-[10px]"></i>
                <span class="text-indigo-600">Édition</span>
            </div>
            <h1 class="text-2xl font-bold text-gray-900">Modifier {{ equipment.name }}</h1>
        </div>

        {% if is_granted('EQUIPMENT_DELETE', equipment) %}
            <form method="post" action="{{ path('equipment_delete', {'id': equipment.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet équipement ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ equipment.id) }}">
                <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 bg-red-50 hover:bg-red-100 text-red-600 text-xs font-bold rounded-xl transition">
                    <i class="fa-regular fa-trash-can"></i> Supprimer
                </button>
            </form>
        {% endif %}
    </div>

    {# Inclusions du sous-formulaire #}
    {{ include('equipment/_form.html.twig', {
        'button_label': 'Mettre à jour'
    }) }}

</div>
{% endblock %}