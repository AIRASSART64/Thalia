
{{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-6 space-y-6">
    
    <h2 class="text-sm font-bold text-gray-900 border-b border-gray-150 pb-3 uppercase tracking-wider">
        Données de la salle
    </h2>

    {# 1. INFORMATIONS GÉNÉRALES #}
    <div class="grid grid-cols-1 gap-4">
        <div>
            {{ form_label(form.name, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.name, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800', 'placeholder': 'Ex: Grande Salle, Le Studio...'}}) }}
            {{ form_errors(form.name, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
        </div>
    </div>

    {# 2. JAUGES ET CAPACITÉS #}
    <div class="border-t border-gray-50 pt-4 space-y-4">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Jauges & Configurations</h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4">
            <div>
                {{ form_label(form.maxCapacity, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                {{ form_widget(form.maxCapacity, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                {{ form_errors(form.maxCapacity, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.seatsCount, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                {{ form_widget(form.seatsCount, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                {{ form_errors(form.seatsCount, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.standingCount, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                {{ form_widget(form.standingCount, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                {{ form_errors(form.standingCount, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.pmrCount, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                {{ form_widget(form.pmrCount, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                {{ form_errors(form.pmrCount, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.invitationQuota, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                {{ form_widget(form.invitationQuota, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                {{ form_errors(form.invitationQuota, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>
        </div>
    </div>

    {# 3. DIMENSIONS DE LA SCÈNE #}
    <div class="border-t border-gray-50 pt-4 space-y-4">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Fiche technique (Scène)</h3>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            <div>
                {{ form_label(form.stageWidth, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                <div class="relative">
                    {{ form_widget(form.stageWidth, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl pl-3 pr-8 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                    <span class="absolute right-3 top-2.5 text-gray-400 text-sm font-medium">m</span>
                </div>
                {{ form_errors(form.stageWidth, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.stageDepth, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                <div class="relative">
                    {{ form_widget(form.stageDepth, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl pl-3 pr-8 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                    <span class="absolute right-3 top-2.5 text-gray-400 text-sm font-medium">m</span>
                </div>
                {{ form_errors(form.stageDepth, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>
            <div>
                {{ form_label(form.stageHeight, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                <div class="relative">
                    {{ form_widget(form.stageHeight, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl pl-3 pr-8 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
                    <span class="absolute right-3 top-2.5 text-gray-400 text-sm font-medium">m</span>
                </div>
                {{ form_errors(form.stageHeight, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>
        </div>
    </div>

    {# 4. MÉDIAS ET DOCUMENTS #}
    <div class="border-t border-gray-50 pt-4 space-y-4">
        <h3 class="text-xs font-bold text-gray-400 uppercase tracking-wider">Médias & Documents</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            
            {# Image de la salle #}
            <div>
                {{ form_label(form.venueImageFile, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-200">
                    {% if venue is defined and venue.id and venue.venueImage %}
                        <div class="w-16 h-16 rounded-xl overflow-hidden bg-gray-200 shrink-0 border border-gray-100 shadow-sm mx-auto sm:mx-0">
                            <img src="{{ path('secure_venue_image', {'id': venue.id}) }}" alt="{{ venue.name }}" " class="w-full h-full object-cover">
                        </div>
                    {% else %}
                        <div class="w-16 h-16 rounded-xl bg-gray-200 flex items-center justify-center shrink-0 text-gray-400 mx-auto sm:mx-0">
                            <i class="fa-regular fa-image text-lg"></i>
                        </div>
                    {% endif %}
                    <div class="flex-grow w-full">
                        {{ form_widget(form.venueImageFile, {'attr': {'class': 'block w-full text-xs text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-indigo-50 file:text-indigo-600 hover:file:bg-indigo-100 file:cursor-pointer transition-colors'}}) }}
                        <p class="text-[11px] text-gray-400 mt-1">Format Image (JPG, PNG, WebP) — Max 1 Mo.</p>
                    </div>
                </div>
                {{ form_errors(form.venueImageFile, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>

            {# Plan technique de la salle #}
            <div>
                {{ form_label(form.venuePlanFile, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 p-4 bg-gray-50 rounded-xl border border-gray-200">
                    <div class="w-16 h-16 rounded-xl bg-gray-200 flex items-center justify-center shrink-0 text-gray-400 mx-auto sm:mx-0">
                        <i class="fa-regular fa-file-pdf text-lg"></i>
                    </div>
                    <div class="flex-grow w-full">
                        {{ form_widget(form.venuePlanFile, {'attr': {'class': 'block w-full text-xs text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-xs file:font-bold file:bg-indigo-50 file:text-indigo-600 hover:file:bg-indigo-100 file:cursor-pointer transition-colors'}}) }}
                        <p class="text-[11px] text-gray-400 mt-1">Plan d'implantation ou fiche PDF — Max 2 Mo.</p>
                    </div>
                </div>
                {{ form_errors(form.venuePlanFile, {'attr': {'class': 'text-red-500 text-xs mt-1'}}) }}
            </div>

        </div>
    </div>

    {# ACTIONS #}
    <div class="border-t border-gray-50 pt-4 flex flex-col-reverse sm:flex-row justify-between items-center gap-4">
        <a href="{{ path('venue_index') }}" class="w-full sm:w-auto text-center text-xs font-semibold text-gray-500 hover:text-gray-700 transition py-2">
            Annuler
        </a>
        <button type="submit" class="w-full sm:w-auto justify-center bg-slate-900 text-white text-xs font-bold px-5 py-2.5 rounded-xl hover:bg-slate-800 transition shadow-sm inline-flex items-center gap-2">
            {{ button_label|default('Enregistrer') }} <i class="fa-solid fa-arrow-right text-[10px]"></i>
        </button>
    </div>

</div>

{{ form_rest(form) }}
{{ form_end(form) }}