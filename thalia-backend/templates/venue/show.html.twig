
{% extends 'base.html.twig' %}

{% block title %}Thalia — {{ venue.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 text-slate-800">
    
  
    <nav class="text-xs text-slate-400 mb-4 px-6 pt-4" aria-label="Breadcrumb">
        <ol class="list-none p-0 inline-flex space-x-2">
            <li class="flex items-center">
                <a href="#" class="hover:text-slate-600">Établissement</a>
                <span class="mx-2">/</span>
            </li>
            <li class="flex items-center">
                <a href="{{ path('venue_index') }}" class="hover:text-slate-600">Salles</a>
                <span class="mx-2">/</span>
            </li>
            <li class="text-slate-600 font-medium" aria-current="page">{{ venue.name }}</li>
        </ol>
    </nav>

    <div class="px-6 pb-12 grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
        
        
        <div class="lg:col-span-2 space-y-6">
            
            {# BANNIÈRE #}
            <div class="relative h-80 rounded-2xl overflow-hidden shadow-lg bg-slate-900 text-white">
                {% if venue.venueImage %}
                    <img src="{{ path('secure_venue_image', {'id': venue.id}) }}" alt="{{ venue.name }}" class="w-full h-full object-cover opacity-80">
                {% else %}
                    {# Image par défaut style théâtre si aucune image n'est présente #}
                    <div class="w-full h-full bg-gradient-to-r from-slate-900 to-indigo-950 flex items-center justify-center">
                        <svg class="w-20 h-20 text-slate-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
                    </div>
                {% endif %}
                
           
                <div class="absolute inset-0 bg-gradient-to-t from-slate-950/80 via-transparent to-transparent"></div>

       
                <div class="absolute bottom-6 left-6 space-y-2">
                    <span class="bg-blue-500 text-white text-[10px] uppercase font-bold tracking-wider px-2.5 py-1 rounded-md shadow-sm">
                        Salle Principale
                    </span>
                    <h1 class="text-3xl font-bold tracking-tight">{{ venue.name }}</h1>
                    <p class="text-sm text-slate-300 flex items-center gap-1.5">
                        <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                        Avenue du Théâtre, Paris
                    </p>
                </div>

                {# Badge Capacité Totale  #}
                <div class="absolute bottom-6 right-6 backdrop-blur-md bg-white/10 border border-white/20 p-4 rounded-xl min-w-[140px] text-center shadow-lg">
                    <span class="text-[10px] uppercase tracking-wider text-slate-300 font-medium block">Capacité Totale</span>
                    <span class="text-3xl font-black text-white block my-0.5">{{ venue.maxCapacity|number_format(0, ',', ' ') }}</span>
                    <span class="text-xs text-slate-300 block">Places assises / debout</span>
                </div>
            </div>

            {# CARTES TECHNIQUE (DIMENSIONS SCÈNE) #}
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                <div class="bg-white border border-slate-100 p-5 rounded-xl shadow-sm text-center flex flex-col justify-center items-center space-y-1">
                    <span class="text-blue-500 text-sm font-semibold flex items-center gap-1">↔ Ouverture Cadre</span>
                    <span class="text-2xl font-bold text-slate-800">{{ venue.stageWidth|default('0.0') }}m</span>
                </div>
                <div class="bg-white border border-slate-100 p-5 rounded-xl shadow-sm text-center flex flex-col justify-center items-center space-y-1">
                    <span class="text-blue-500 text-sm font-semibold flex items-center gap-1">📋 Profondeur</span>
                    <span class="text-2xl font-bold text-slate-800">{{ venue.stageDepth|default('0.0') }}m</span>
                </div>
                <div class="bg-white border border-slate-100 p-5 rounded-xl shadow-sm text-center flex flex-col justify-center items-center space-y-1">
                    <span class="text-blue-500 text-sm font-semibold flex items-center gap-1">↕ Hauteur Sous Gril</span>
                    <span class="text-2xl font-bold text-slate-800">{{ venue.stageHeight|default('0.0') }}m</span>
                </div>
            </div>

            {# TABLEAU : INVENTAIRE SCÉNIQUE #}
            <div class="bg-white border border-slate-100 rounded-xl shadow-sm overflow-hidden p-6">
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
                    <h2 class="text-lg font-bold text-slate-800">Inventaire Scénique</h2>
                    <div class="flex gap-2 w-full sm:w-auto">
                        <button class="px-4 py-2 border border-slate-200 text-slate-600 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors">Exporter PDF</button>
                        {% if is_granted('VENUE_EDIT', venue) %}
                            <button class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors shadow-sm">Ajouter Équipement</button>
                        {% endif %}
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead>
                            <tr class="border-b border-slate-100 text-[11px] font-bold text-slate-400 uppercase bg-slate-50/50">
                                <th class="py-3 px-4">Équipement</th>
                                <th class="py-3 px-4">Catégorie</th>
                                <th class="py-3 px-4">État</th>
                                <th class="py-3 px-4 text-right">Dernière Maint.</th>
                            </tr>
                        </thead>
                        {# <tbody class="divide-y divide-slate-100 text-slate-600">
                            {% for equipment in venue.equipments %}
                                <tr class="hover:bg-slate-50/80 transition-colors">
                                    <td class="py-3.5 px-4 font-semibold text-slate-800">{{ equipment.name }}</td>
                                    <td class="py-3.5 px-4"><span class="bg-slate-100 text-slate-600 px-2 py-1 rounded text-xs">Scénographie</span></td>
                                    <td class="py-3.5 px-4">
                                        <span class="bg-emerald-50 text-emerald-600 px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">Fonctionnel</span>
                                    </td>
                                    <td class="py-3.5 px-4 text-right text-slate-400">12/08/2025</td>
                                </tr>
                            {% else %}
                                <tr>
                                    <td colspan="4" class="py-8 text-center text-slate-400 italic bg-slate-50/30 rounded-xl">
                                        Aucun équipement spécifique lié à cette salle pour le moment.
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody> #}
                    </table>
                </div>
            </div>
        </div>

        {# BARRE LATÉRALE DROITE (EXPLOITATION & MANAGEMENT) #}
        <div class="space-y-6">
            
            {# BLOC : SPECTACLE ACTUEL #}
            <div class="bg-white border border-slate-100 rounded-xl shadow-sm p-6 space-y-4">
                <div class="flex justify-between items-center border-b border-slate-100 pb-3">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Spectacle Actuel</h3>
                    <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
                </div>
                
                <div class="flex gap-4 items-start">
                    {# Affiche de l'événement en cours (Exemple statique issu de la maquette Thalia) #}
                    <div class="w-20 h-28 bg-slate-200 rounded-lg overflow-hidden shadow-inner flex-shrink-0">
                        <div class="w-full h-full bg-gradient-to-br from-indigo-900 to-slate-900 flex items-center justify-center p-2 text-center text-[10px] text-indigo-200 font-bold">
                            Le Lac des Cygnes
                        </div>
                    </div>
                    <div class="space-y-1">
                        <h4 class="font-bold text-blue-600 text-base leading-tight hover:underline cursor-pointer">Le Lac des Cygnes</h4>
                        <p class="text-xs text-slate-400">Ballet de l'Opéra National</p>
                        <p class="text-xs text-slate-500 pt-2 flex items-center gap-1">📅 Jusqu'au 24 Oct.</p>
                    </div>
                </div>

                <div class="pt-2 space-y-2 text-sm border-t border-slate-50">
                    <div class="flex justify-between">
                        <span class="text-slate-400">Taux d'occupation :</span>
                        <span class="font-bold text-slate-800">94%</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-slate-400">Prochaine séance :</span>
                        <span class="font-semibold text-slate-700">20:30 <span class="text-xs text-blue-500 font-medium">(Ce soir)</span></span>
                    </div>
                </div>

                <button class="w-full py-2.5 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors shadow-sm mt-2">
                    Gérer la billetterie
                </button>
            </div>

            {# BLOC : ÉTAT DES ÉQUIPEMENTS #}
            <div class="bg-white border border-slate-100 rounded-xl shadow-sm p-6 space-y-4">
                <div class="flex justify-between items-center">
                    <h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">État Équipements</h3>
                    <a href="#" class="text-xs text-blue-500 hover:underline font-medium">Voir tout</a>
                </div>

                <div class="space-y-3">
                    {# Exemple 1 : Ok #}
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-white rounded-md text-slate-400 text-xs shadow-sm">📍</div>
                            <div>
                                <h5 class="text-xs font-bold text-slate-800">Gril Motorisé</h5>
                                <p class="text-[10px] text-slate-400">24 perches actives</p>
                            </div>
                        </div>
                        <span class="text-emerald-500 text-lg">✓</span>
                    </div>
                    {# Exemple 2 : Ok #}
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-white rounded-md text-slate-400 text-xs shadow-sm">✉</div>
                            <div>
                                <h5 class="text-xs font-bold text-slate-800">Système L-Acoustics</h5>
                                <p class="text-[10px] text-slate-400">Calibrage OK</p>
                            </div>
                        </div>
                        <span class="text-emerald-500 text-lg">✓</span>
                    </div>
                    {# Exemple 3 : Alerte #}
                    <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg border border-slate-100">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-white rounded-md text-slate-400 text-xs shadow-sm">🎛️</div>
                            <div>
                                <h5 class="text-xs font-bold text-slate-800">Console MA3</h5>
                                <p class="text-[10px] text-rose-500 font-medium">Maintenance requise</p>
                            </div>
                        </div>
                        <span class="text-rose-500 text-xs bg-rose-50 px-1.5 py-0.5 rounded-full font-bold">⚠️</span>
                    </div>
                </div>
            </div>

            {# BOUTON ÉDITION GLOBALE SI AUTORISÉ #}
            {% if is_granted('VENUE_EDIT', venue) %}
                <div class="flex gap-3">
                    <a href="{{ path('venue_edit', {'id': venue.id}) }}" class="w-full text-center py-2.5 bg-slate-800 hover:bg-slate-900 text-white rounded-lg text-sm font-medium transition-colors shadow-sm">
                        Modifier 
                    </a>
                </div>
            {% endif %}

        </div>
    </div>
</div>
{% endblock %}