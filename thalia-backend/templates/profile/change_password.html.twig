{% extends 'base.html.twig' %}

{% block title %}Modifier mon mot de passe - Thalia{% endblock %}

{% block body %}
<div class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4 overflow-y-auto font-sans">
    <div class="bg-white w-full max-w-md rounded-2xl shadow-2xl border border-slate-100 p-8 relative">
        
        <div class="text-center mb-6">
            <h1 class="text-xl font-bold text-slate-900 tracking-tight">Modifier le mot de passe</h1>
            <p class="text-xs text-slate-400 mt-1">Pour sécuriser votre accès, choisissez un mot de passe robuste.</p>
        </div>

        {{ form_start(form, {'attr': {'class': 'space-y-4', 'novalidate': 'novalidate'}}) }}
            
            <div>
                <label class="block text-xs font-bold text-slate-700 mb-1">Mot de passe actuel</label>
                {{ form_widget(form.currentPassword, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500'}}) }}
                {{ form_errors(form.currentPassword, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-700 mb-1">Nouveau mot de passe</label>
                {{ form_widget(form.newPassword.first, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500'}}) }}
                {{ form_errors(form.newPassword.first, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
            </div>

            <div>
                <label class="block text-xs font-bold text-slate-700 mb-1">Confirmer le nouveau mot de passe</label>
                {{ form_widget(form.newPassword.second, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500'}}) }}
            </div>

            <div class="flex items-center gap-3 pt-2">
                <a href="{{ path('profile_index') }}" class="w-1/2 text-center px-4 py-2.5 text-sm font-medium text-slate-700 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 transition">
                    Annuler
                </a>
                <button type="submit" class="w-1/2 bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2.5 px-4 rounded-xl text-sm transition shadow-sm">
                    Mettre à jour
                </button>
            </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}