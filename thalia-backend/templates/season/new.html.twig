{% extends 'base.html.twig' %}

{% block title %}Nouvelle Saison{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 py-8">
    <div class="mb-6">
        <a href="{{ path('season_index') }}" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-slate-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Retour à la liste
        </a>
        <h1 class="text-2xl font-bold text-slate-800 mt-2">Créer une saison culturelle</h1>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm">
        {{ include('season/_form.html.twig', {'button_label': 'Créer la saison'}) }}
    </div>
</div>
{% endblock %}