{% extends 'base.html.twig' %}

{% block title %}Saison - {{ season.name }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50/50 p-6 lg:p-10 font-sans">

    {# EN-TÊTE / BREADCRUMB #}
    <div class="mb-8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
            <nav class="flex text-[11px] font-semibold text-slate-400 uppercase tracking-wider gap-2 mb-2">
                <a href="#" class="hover:text-slate-600">Saisons</a>
                <span>&gt;</span>
                <span class="text-blue-500">{{ season.name }}</span>
            </nav>
            <h1 class="text-2xl font-black text-slate-900 tracking-tight">
                Gestion Financière & Budgétaire
            </h1>
            <p class="text-xs text-slate-400 mt-1">
                Période du {{ season.startDate|date('d/m/Y') }} au {{ season.endDate|date('d/m/Y') }}
            </p>
        </div>

        <div class="flex items-center gap-3">
            <a href="{{ path('season_index') }}" class="inline-flex items-center gap-2 bg-white border border-slate-200 text-slate-700 font-semibold px-4 py-2 rounded-xl text-xs shadow-sm hover:bg-slate-50 transition">
                <i class="fa-solid fa-arrow-left text-slate-400"></i> Retour aux saisons
            </a>
            {% if is_granted('FINANCIAL_CREATE') %}
                {# BOUTON SUR LE MÊME MODÈLE QUE 'CRÉER UNE SALLE' #}
                <a href="{{ path('financial_new', {'season': season.id}) }}" class="inline-flex items-center gap-2 bg-blue-600 text-white font-semibold px-4 py-2 rounded-xl text-xs shadow-sm hover:bg-blue-700 transition">
                    <i class="fa-solid fa-plus text-blue-200"></i> Ajouter une ligne
                </a>
            {% endif %}
        </div>
    </div>

    {# SYNTHÈSE / CARTES FINANCIÈRES #}
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 flex items-center justify-between">
            <div>
                <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Total Recettes (Crédits)</span>
                <p class="text-xl font-black font-mono text-emerald-600">
                    +{{ season.totalCreditHt|number_format(2, ',', ' ') }} € <span class="text-xs font-semibold text-slate-400">HT</span>
                </p>
            </div>
            <div class="w-10 h-10 bg-emerald-50 text-emerald-500 rounded-xl flex items-center justify-center text-sm">
                <i class="fa-solid fa-arrow-trend-up"></i>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 flex items-center justify-between">
            <div>
                <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Total Dépenses (Débits)</span>
                <p class="text-xl font-black font-mono text-rose-600">
                    -{{ season.totalDebitHt|number_format(2, ',', ' ') }} € <span class="text-xs font-semibold text-slate-400">HT</span>
                </p>
            </div>
            <div class="w-10 h-10 bg-rose-50 text-rose-500 rounded-xl flex items-center justify-center text-sm">
                <i class="fa-solid fa-arrow-trend-down"></i>
            </div>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 flex items-center justify-between">
            <div>
                <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Solde Net Prévisionnel</span>
                <p class="text-xl font-black font-mono {{ season.netBalance >= 0 ? 'text-blue-600' : 'text-rose-600' }}">
                    {{ season.netBalance|number_format(2, ',', ' ') }} € <span class="text-xs font-semibold text-slate-400">HT</span>
                </p>
            </div>
            <div class="w-10 h-10 bg-blue-50 text-blue-500 rounded-xl flex items-center justify-center text-sm">
                <i class="fa-solid fa-scale-balanced"></i>
            </div>
        </div>
    </div>

    {# SECTION DÉBITS & CRÉDITS (TABLEAUX DISTINCTS) #}
    <div class="space-y-8">

        {# --- TABLEAU DES CRÉDITS (RECETTES) --- #}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-emerald-50 text-emerald-600 rounded-lg flex items-center justify-center text-sm">
                        <i class="fa-solid fa-circle-plus"></i>
                    </div>
                    <div>
                        <h2 class="text-sm font-bold text-slate-800 tracking-tight">Crédits & Recettes</h2>
                        <p class="text-[11px] text-slate-400 mt-0.5">Produits et financements rattachés à la saison</p>
                    </div>
                </div>

                <span class="bg-emerald-50 text-emerald-700 text-xs font-bold px-3 py-1 rounded-xl border border-emerald-100">
                    {{ season.credits|length }} ligne(s)
                </span>
            </div>

            {% if season.credits is not empty %}
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-xs text-slate-600">
                        <thead>
                            <tr class="border-b border-slate-100 text-[10px] font-bold text-slate-400 uppercase tracking-wider">
                                <th class="pb-3">Catégorie</th>
                                <th class="pb-3">Description</th>
                                <th class="pb-3">Montant HT</th>
                                <th class="pb-3">Taux TVA</th>
                                <th class="pb-3 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            {% for line in season.credits %}
                                <tr class="hover:bg-slate-50/50 transition">
                                    <td class="py-3.5 font-bold text-slate-800">
                                        {{ line.category.label|default('Non catégorisé') }}
                                    </td>
                                    <td class="py-3.5 text-slate-500">
                                        {{ line.description|default('-') }}
                                    </td>
                                    <td class="py-3.5 font-mono font-bold text-emerald-600">
                                        +{{ line.amountHt|number_format(2, ',', ' ') }} €
                                    </td>
                                    <td class="py-3.5 font-mono text-slate-400">
                                        {{ line.vatRate ? line.vatRate.value ~ '%' : '-' }}
                                    </td>
                                    <td class="py-3.5 text-right space-x-2">
                                        {% if is_granted('FINANCIAL_EDIT', line) %}
                                            <a href="{{ path('financial_edit', {'id': line.id}) }}" class="inline-flex items-center gap-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold px-2.5 py-1 rounded-lg text-[10px] transition">
                                                <i class="fa-solid fa-pen text-[9px]"></i> Modifier
                                            </a>
                                        {% endif %}
                                        {% if is_granted('FINANCIAL_DELETE', line) %}
                                            <form method="post" action="{{ path('financial_delete', {'id': line.id}) }}" class="inline" onsubmit="return confirm('Confirmer la suppression ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ line.id) }}">
                                                <button type="submit" class="inline-flex items-center gap-1 bg-rose-50 hover:bg-rose-100 text-rose-600 font-semibold px-2.5 py-1 rounded-lg text-[10px] transition">
                                                    <i class="fa-solid fa-trash text-[9px]"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-8 bg-slate-50/50 rounded-2xl border border-dashed border-slate-200">
                    <p class="text-xs font-medium text-slate-400">Aucun crédit ou recette enregistrée.</p>
                </div>
            {% endif %}
        </div>

        {# --- TABLEAU DES DÉBITS (DÉPENSES) --- #}
        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-8">
            <div class="flex items-center justify-between mb-6">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-rose-50 text-rose-500 rounded-lg flex items-center justify-center text-sm">
                        <i class="fa-solid fa-circle-minus"></i>
                    </div>
                    <div>
                        <h2 class="text-sm font-bold text-slate-800 tracking-tight">Débits & Charges</h2>
                        <p class="text-[11px] text-slate-400 mt-0.5">Coûts d'exploitation et charges prévisionnelles</p>
                    </div>
                </div>

                <span class="bg-rose-50 text-rose-700 text-xs font-bold px-3 py-1 rounded-xl border border-rose-100">
                    {{ season.debits|length }} ligne(s)
                </span>
            </div>

            {% if season.debits is not empty %}
                <div class="overflow-x-auto">
                    <table class="w-full text-left text-xs text-slate-600">
                        <thead>
                            <tr class="border-b border-slate-100 text-[10px] font-bold text-slate-400 uppercase tracking-wider">
                                <th class="pb-3">Catégorie</th>
                                <th class="pb-3">Description</th>
                                <th class="pb-3">Montant HT</th>
                                <th class="pb-3">Taux TVA</th>
                                <th class="pb-3 text-right">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            {% for line in season.debits %}
                                <tr class="hover:bg-slate-50/50 transition">
                                    <td class="py-3.5 font-bold text-slate-800">
                                        {{ line.category.label|default('Non catégorisé') }}
                                    </td>
                                    <td class="py-3.5 text-slate-500">
                                        {{ line.description|default('-') }}
                                    </td>
                                    <td class="py-3.5 font-mono font-bold text-rose-600">
                                        -{{ line.amountHt|number_format(2, ',', ' ') }} €
                                    </td>
                                    <td class="py-3.5 font-mono text-slate-400">
                                        {{ line.vatRate ? line.vatRate.value ~ '%' : '-' }}
                                    </td>
                                    <td class="py-3.5 text-right space-x-2">
                                        {% if is_granted('FINANCIAL_EDIT', line) %}
                                            <a href="{{ path('financial_edit', {'id': line.id}) }}" class="inline-flex items-center gap-1 bg-slate-100 hover:bg-slate-200 text-slate-700 font-semibold px-2.5 py-1 rounded-lg text-[10px] transition">
                                                <i class="fa-solid fa-pen text-[9px]"></i> Modifier
                                            </a>
                                        {% endif %}
                                        {% if is_granted('FINANCIAL_DELETE', line) %}
                                            <form method="post" action="{{ path('financial_delete', {'id': line.id}) }}" class="inline" onsubmit="return confirm('Confirmer la suppression ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ line.id) }}">
                                                <button type="submit" class="inline-flex items-center gap-1 bg-rose-50 hover:bg-rose-100 text-rose-600 font-semibold px-2.5 py-1 rounded-lg text-[10px] transition">
                                                    <i class="fa-solid fa-trash text-[9px]"></i>
                                                </button>
                                            </form>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="text-center py-8 bg-slate-50/50 rounded-2xl border border-dashed border-slate-200">
                    <p class="text-xs font-medium text-slate-400">Aucune charge ou dépense enregistrée.</p>
                </div>
            {% endif %}
        </div>

    </div>

</div>
{% endblock %}