{% extends 'base.html.twig' %}

{% block title %}Modifier la Saison{% endblock %}

{% block body %}
<div class="max-w-2xl mx-auto px-4 py-8">
    <div class="mb-6">
        <a href="{{ path('season_index') }}" class="inline-flex items-center gap-1 text-sm text-slate-500 hover:text-slate-700 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Retour à la liste
        </a>
        <h1 class="text-2xl font-bold text-slate-800 mt-2">Modifier : {{ season.name }}</h1>
    </div>

    <div class="bg-white border border-slate-200 rounded-2xl p-6 shadow-sm space-y-6">
        {{ include('season/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}

        {# Zone de suppression sécurisée #}
        <div class="pt-6 border-t border-slate-100 flex items-center justify-between">
            <span class="text-xs text-slate-400">Zone de danger</span>
            <form method="post" action="{{ path('season_delete', {'id': season.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette saison ?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ season.id) }}">
                <button type="submit" class="px-3 py-1.5 text-xs font-medium text-red-600 hover:text-white hover:bg-red-600 rounded-lg border border-red-200 transition-all">
                    Supprimer la saison
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}