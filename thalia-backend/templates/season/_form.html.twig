{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

    {# Nom de la saison #}
    <div class="space-y-2">
        {{ form_label(form.name, 'Nom de la saison', {'label_attr': {'class': 'block text-xs font-bold text-slate-700 uppercase tracking-wider'}}) }}
        <div class="relative">
            <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                <i class="fa-solid fa-heading text-sm"></i>
            </div>
            {{ form_widget(form.name, {'attr': {
                'placeholder': 'Ex: Saison 2025-2026',
                'class': 'w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 focus:border-sky-500 focus:bg-white focus:ring-2 focus:ring-sky-500/20 rounded-xl text-xs font-semibold text-slate-800 transition shadow-sm outline-none'
            }}) }}
        </div>
        {% if form.name.vars.errors|length > 0 %}
            <p class="text-xs text-rose-500 font-medium mt-1 flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i>
                {{ form_errors(form.name) }}
            </p>
        {% endif %}
    </div>

    {# Ligne 2 : Date de début & Date de fin #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        {# Date de début (start_date) #}
        <div class="space-y-2">
            {{ form_label(form.start_date, 'Date de début', {'label_attr': {'class': 'block text-xs font-bold text-slate-700 uppercase tracking-wider'}}) }}
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                    <i class="fa-solid fa-calendar-days text-sm"></i>
                </div>
                {{ form_widget(form.start_date, {'attr': {
                    'class': 'w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 focus:border-sky-500 focus:bg-white focus:ring-2 focus:ring-sky-500/20 rounded-xl text-xs font-semibold text-slate-800 transition shadow-sm outline-none'
                }}) }}
            </div>
            {% if form.start_date.vars.errors|length > 0 %}
                <p class="text-xs text-rose-500 font-medium mt-1 flex items-center gap-1">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    {{ form_errors(form.start_date) }}
                </p>
            {% endif %}
        </div>

        {# Date de fin (end_date) #}
        <div class="space-y-2">
            {{ form_label(form.end_date, 'Date de fin', {'label_attr': {'class': 'block text-xs font-bold text-slate-700 uppercase tracking-wider'}}) }}
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                    <i class="fa-solid fa-calendar-check text-sm"></i>
                </div>
                {{ form_widget(form.end_date, {'attr': {
                    'class': 'w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 focus:border-sky-500 focus:bg-white focus:ring-2 focus:ring-sky-500/20 rounded-xl text-xs font-semibold text-slate-800 transition shadow-sm outline-none'
                }}) }}
            </div>
            {% if form.end_date.vars.errors|length > 0 %}
                <p class="text-xs text-rose-500 font-medium mt-1 flex items-center gap-1">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    {{ form_errors(form.end_date) }}
                </p>
            {% endif %}
        </div>

    </div>

    {# Saison active (Si présent dans le FormType) #}
    {% if form.is_active is defined %}
        <div class="space-y-2">
            <div class="flex items-center gap-3 p-3.5 bg-slate-50 border border-slate-200 rounded-xl">
                {{ form_widget(form.is_active, {'attr': {
                    'class': 'w-4 h-4 text-sky-500 bg-white border-slate-300 rounded focus:ring-sky-500/20 focus:ring-2 cursor-pointer'
                }}) }}
                {{ form_label(form.is_active, 'Définir comme saison active', {'label_attr': {'class': 'text-xs font-bold text-slate-700 cursor-pointer mb-0'}}) }}
            </div>
            {% if form.is_active.vars.errors|length > 0 %}
                <p class="text-xs text-rose-500 font-medium mt-1 flex items-center gap-1">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    {{ form_errors(form.is_active) }}
                </p>
            {% endif %}
        </div>
    {% endif %}

    {# Boutons d'action #}
    <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
        <a href="{{ path('season_index') }}" class="px-5 py-2.5 rounded-xl border border-slate-200 hover:bg-slate-50 text-slate-600 font-semibold text-xs transition">
            Annuler
        </a>
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-sky-500 hover:bg-sky-600 text-white font-semibold text-xs shadow-md shadow-sky-500/20 transition">
            <i class="fa-solid fa-check text-xs"></i>
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>

{{ form_end(form) }}