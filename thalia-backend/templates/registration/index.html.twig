{% extends 'base.html.twig' %}

{% block title %}Créer un compte - Thalia{% endblock %}

{% block body %}
{# 1. LE CONTENEUR OVERLAY (Filtre sombre en arrière-plan qui simule la superposition sur la Home) #}
<div class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4 overflow-y-auto font-sans">
    
    {# 2. LA MODALE BLANCHE (Centrée, ombragée et arrondie) #}
    <div class="bg-white w-full max-w-lg rounded-2xl shadow-2xl border border-slate-100 p-8 my-8 relative">
        
        {# En-tête de la maquette #}
        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Créer un compte</h1>
            <p class="text-xs text-indigo-500 mt-1 font-medium">Rejoignez Thalia pour piloter votre programmation culturelle.</p>
        </div>

        {# Affichage des messages flash d'erreur #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 p-3 rounded-lg text-xs font-medium border bg-rose-50 border-rose-100 text-rose-700">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Désactivation du HTML5 validation natif pour laisser Tailwind et Symfony gérer proprement #}
        {{ form_start(registrationForm, {'attr': {'class': 'space-y-4', 'novalidate': 'novalidate'}}) }}
            
            {# Ligne : Prénom / Nom #}
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Prénom</label>
                    {{ form_widget(registrationForm.firstName, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition placeholder-slate-300', 'placeholder': 'Jean'}}) }}
                    {{ form_errors(registrationForm.firstName, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Nom</label>
                    {{ form_widget(registrationForm.lastName, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition placeholder-slate-300', 'placeholder': 'Dupont'}}) }}
                    {{ form_errors(registrationForm.lastName, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
                </div>
            </div>

            {# Ligne : Numéro de SIRET / Établissement #}
            <div>
                <label class="block text-xs font-bold text-slate-700 mb-1">Numéro de SIRET</label>
                {{ form_widget(registrationForm.siret, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-lg text-sm font-mono tracking-wider focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition placeholder-slate-300', 'placeholder': '14 chiffres obligatoire'}}) }}
                <p class="text-[10px] text-slate-400 mt-1">Vérification en temps réel auprès de l'API du Ministère de la Culture.</p>
                {{ form_errors(registrationForm.siret, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
            </div>

            {# Ligne : Email #}
            <div>
                <label class="block text-xs font-bold text-slate-700 mb-1">Adresse e-mail professionnelle</label>
                {{ form_widget(registrationForm.email, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition placeholder-slate-300', 'placeholder': 'nom@institution.fr'}}) }}
                {{ form_errors(registrationForm.email, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
            </div>

            {# Ligne : Mot de passe (S'adapte si c'est un RepeatedType Symfony) #}
            {% if registrationForm.password.first is defined %}
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1">Mot de passe</label>
                        {{ form_widget(registrationForm.password.first, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition'}}) }}
                        {{ form_errors(registrationForm.password.first, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
                    </div>
                    <div>
                        <label class="block text-xs font-bold text-slate-700 mb-1">Confirmer le mot de passe</label>
                        {{ form_widget(registrationForm.password.second, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition'}}) }}
                    </div>
                </div>
            {% else %}
                <div>
                    <label class="block text-xs font-bold text-slate-700 mb-1">Mot de passe</label>
                    {{ form_widget(registrationForm.password, {'attr': {'class': 'w-full px-3 py-2 border border-slate-200 rounded-lg text-sm focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition'}}) }}
                    {{ form_errors(registrationForm.password, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
                </div>
            {% endif %}

            {# Masquer le reste automatique des champs #}
            {{ form_rest(registrationForm) }}

            {# Bouton de Soumission Principal (Bleu azur de la maquette) #}
            <div class="pt-2">
                <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2.5 px-4 rounded-xl text-sm transition shadow-sm shadow-blue-100">
                    Créer mon compte
                </button>
            </div>
            
            {# Footer de la modale #}
            <div class="text-center pt-4 border-t border-slate-50">
                <p class="text-xs text-slate-500">
                    Déjà un compte ? 
                    <a href="{{ path('home') }}" class="text-blue-500 font-semibold hover:underline">Se connecter</a>
                </p>
            </div>

        {{ form_end(registrationForm) }}
    </div>
</div>
{% endblock %}