{% extends 'base.html.twig' %}

{% block title %}Thalia - Modifier {{ contact.firstName }} {{ contact.lastName }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 text-slate-800">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-6">
        
        {# ─── BREADCRUMB & HEADER ─── #}
        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
                <nav class="flex mb-2 text-xs font-semibold text-slate-400 uppercase tracking-wider gap-2">
                    <a href="{{ path('contact_index') }}" class="hover:text-slate-600">CRM</a>
                    <span>/</span>
                    <a href="{{ path('contact_show', {'id': contact.id}) }}" class="hover:text-slate-600">{{ contact.firstName }} {{ contact.lastName }}</a>
                    <span>/</span>
                    <span class="text-slate-500">Modifier</span>
                </nav>
                <h1 class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tight">
                    Modifier le contact
                </h1>
            </div>
            
            {# Action de suppression sécurisée #}
            <div>
                <form method="post" action="{{ path('contact_delete', {'id': contact.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer définitivement ce contact ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ contact.id) }}">
                    <button type="submit" class="inline-flex items-center gap-1.5 px-3 py-2 rounded-xl bg-red-50 hover:bg-red-100 text-red-600 font-bold text-xs transition">
                        <i class="fa-regular fa-trash-can"></i> Supprimer le contact
                    </button>
                </form>
            </div>
        </div>

        {# ─── INCLUSION DU FORMULAIRE PARTAGÉ ─── #}
        {{ include('contact/_form.html.twig', {'button_label': 'Enregistrer les modifications'}) }}

    </div>
</div>
{% endblock %}