{% extends 'base.html.twig' %}

{% block title %}Thalia - Base de Contacts{% endblock %}

{% block body %}
<div class="min-h-screen bg-slate-50 text-slate-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">
        
        {# ─── HEADER ─── #}
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <nav class="flex mb-2 text-xs font-semibold text-slate-400 uppercase tracking-wider gap-2">
                    <a href="#" class="hover:text-slate-600">CRM</a>
                    <span>/</span>
                    <span class="text-slate-500">Base de Contacts</span>
                </nav>
                <h1 class="text-2xl sm:text-3xl font-black text-slate-900 tracking-tight">
                    Base de Contacts
                </h1>
                <p class="text-sm text-slate-500 mt-1">
                    Gérez vos relations professionnelles.
                </p>
            </div>
            <div>
                <a href="{{ path('contact_new') }}" class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-xs sm:text-sm font-bold px-4 py-2.5 rounded-xl transition shadow-sm hover:shadow-md">
                    <i class="fa-solid fa-plus text-xs"></i> Nouveau Contact
                </a>
            </div>
        </div>

        {# ─── SECTION FILTRES & STATS (GRID RESPONSIVE) ─── #}
        <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
            
            {# Onglets, recherche et filtre (col-span-3) #}
            <div class="lg:col-span-3 bg-white rounded-2xl border border-slate-100 shadow-sm p-4 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                {# Filtres par Type de contact (Pills) #}
                <div class="flex flex-wrap items-center gap-2">
                    <button class="px-4 py-2 rounded-xl text-xs font-bold bg-indigo-600 text-white transition">
                        Tous
                    </button>
                    <button class="px-4 py-2 rounded-xl text-xs font-bold bg-slate-50 text-slate-600 hover:bg-slate-100 transition">
                        Agents
                    </button>
                    <button class="px-4 py-2 rounded-xl text-xs font-bold bg-slate-50 text-slate-600 hover:bg-slate-100 transition">
                        Directeurs
                    </button>
                    <button class="px-4 py-2 rounded-xl text-xs font-bold bg-slate-50 text-slate-600 hover:bg-slate-100 transition">
                        Techniciens
                    </button>
                </div>

                {# Boutons de tri et d'affichage #}
                <div class="flex items-center gap-2 self-end sm:self-auto border-t sm:border-t-0 pt-3 sm:pt-0">
                    <button class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-50 rounded-lg transition" title="Filtrer">
                        <i class="fa-solid fa-sliders"></i>
                    </button>
                    <button class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-50 rounded-lg transition" title="Trier par ordre alphabétique">
                        <i class="fa-solid fa-arrow-down-a-z"></i>
                    </button>
                    <div class="h-6 w-[1px] bg-slate-200 mx-1"></div>
                    <button class="p-2 text-indigo-600 bg-indigo-50 rounded-lg transition" title="Vue Grille">
                        <i class="fa-solid fa-grip-vertical"></i>
                    </button>
                    <button class="p-2 text-slate-400 hover:text-slate-600 hover:bg-slate-50 rounded-lg transition" title="Vue Liste">
                        <i class="fa-solid fa-list"></i>
                    </button>
                </div>
            </div>

            <div class="bg-indigo-600 text-white rounded-2xl p-5 shadow-sm relative overflow-hidden flex flex-col justify-between">
          
                <div class="absolute -right-6 -bottom-6 text-white opacity-5 text-8xl">
                    <i class="fa-solid fa-users"></i>
                </div>
                
                <span class="text-xs font-extrabold uppercase tracking-wider text-indigo-200">Total Contacts</span>
                <div class="mt-2 flex items-baseline gap-2">
                    <span class="text-3xl font-black tracking-tight">{{ contacts|length }}</span>
                    <span class="text-xs font-bold text-emerald-300 flex items-center gap-0.5">
                        <i class="fa-solid fa-caret-up"></i> Actifs
                    </span>
                </div>
            </div>
        </div>

        {# ─── GRILLE DE CARDS (CONTACTS EN AVANT) ─── #}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
            
            {% for contact in contacts %}
                
                <a href="{{ path('contact_show', {'id': contact.id}) }}" class="block bg-white rounded-2xl border border-slate-100 shadow-sm p-5 flex flex-col justify-between relative group hover:shadow-md hover:border-indigo-100 transition duration-300">
                    
                    {# Badge du rôle #}
                    {# <span class="absolute top-4 right-4 text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full 
                        {% if contact.role == 'Agent' %}
                            bg-indigo-50 text-indigo-600
                        {% elseif contact.role == 'Directeur' or contact.role == 'Directrice' %}
                            bg-orange-50 text-orange-600
                        {% else %}
                            bg-sky-50 text-sky-600
                        {% endif %}">
                        {{ contact.role|default('Contact') }}
                    </span> #}

                    <div class="flex items-start gap-4">
                        
                        <div class="w-12 h-12 rounded-xl bg-slate-50 flex items-center justify-center shrink-0 border border-slate-150 text-slate-500 font-bold text-sm group-hover:bg-indigo-50 group-hover:border-indigo-100 group-hover:text-indigo-600 transition duration-300">
                            {{ contact.firstName|slice(0,1)|upper }}{{ contact.lastName|slice(0,1)|upper }}
                        </div>
                        <div class="min-w-0">
                            <h3 class="font-bold text-slate-900 group-hover:text-indigo-600 transition truncate">
                                {{ contact.firstName }} {{ contact.lastName }}
                            </h3>
                            <p class="text-xs text-slate-400 mt-0.5 truncate">{{ contact.companyName|default('Indépendant') }}</p>
                        </div>
                    </div>

                    <div class="border-t border-slate-50 pt-4 mt-5 flex items-center justify-between text-xs text-slate-400">
                        <span class="flex items-center gap-1.5 font-medium">
                            <i class="fa-solid fa-masks-theater text-indigo-400"></i> 
                            {{ contact.shows|length }} spectacle(s)
                        </span>
                        
                        {# <span class="text-indigo-600 font-extrabold flex items-center gap-1">
                            Détails <i class="fa-solid fa-arrow-right text-[10px] transform transition-transform group-hover:translate-x-1"></i>
                        </span> #}
                    </div>
                </a>
            {% else %}
                <div class="col-span-full bg-white rounded-2xl border border-slate-100 p-8 text-center text-slate-500">
                    Aucun contact enregistré pour le moment.
                </div>
            {% endfor %}

        </div>

        {# ─── VUE TABLEAU ─── #}
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
            <div class="p-6 border-b border-slate-100 flex items-center justify-between">
                <h2 class="text-sm font-bold text-slate-900 uppercase tracking-wider">
                    Tous les contacts
                </h2>
                <span class="text-xs text-slate-400">
                    {{ contacts|length }} ligne(s)
                </span>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-slate-50/70 border-b border-slate-100 text-[11px] font-black text-slate-400 uppercase tracking-wider">
                            <th class="py-4 px-6">Contact</th>
                            <th class="py-4 px-6">Organisation</th>
                            <th class="py-4 px-6">Rôle</th>
                            <th class="py-4 px-6">Email / Téléphone</th>
                            <th class="py-4 px-6">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        
                        {% for contact in contacts %}
                            <tr class="hover:bg-slate-50/50 transition duration-150">
                                <td class="py-4 px-6">
                                    <div class="flex items-center gap-3">
                                        <div class="w-9 h-9 rounded-lg bg-indigo-50 border border-indigo-100 flex items-center justify-center text-xs font-extrabold text-indigo-600 shrink-0">
                                            {{ contact.firstName|slice(0,1)|upper }}{{ contact.lastName|slice(0,1)|upper }}
                                        </div>
                                        <div>
                                            <h4 class="font-bold text-slate-900">{{ contact.firstName }} {{ contact.lastName }}</h4>
                                            <span class="text-[11px] text-slate-400">{{ contact.email }}</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-4 px-6 font-medium text-slate-600">
                                    {{ contact.companyName|default('—') }}
                                </td>
                                <td class="py-4 px-6">
                                    <span class="text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-md
                                        {% if contact.role == 'Agent' %}
                                            bg-indigo-50 text-indigo-600
                                        {% elseif contact.role == 'Directeur' or contact.role == 'Directrice' %}
                                            bg-orange-50 text-orange-600
                                        {% else %}
                                            bg-sky-50 text-sky-600
                                        {% endif %}">
                                        {{ contact.role|default('Contact') }}
                                    </span>
                                </td>
                                <td class="py-4 px-6 text-slate-500 font-medium text-xs">
                                    <div>{{ contact.email }}</div>
                                    <div class="text-[10px] text-slate-400">{{ contact.phone|default('Aucun téléphone') }}</div>
                                </td>
                                <td class="py-4 px-6 text-left">
                                    <div class="flex items-center gap-2">
                                        <a href="{{ path('contact_show', {'id': contact.id}) }}" class="text-slate-400 hover:text-indigo-600 p-1.5 rounded-lg hover:bg-indigo-50 transition" title="Consulter">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <a href="{{ path('contact_edit', {'id': contact.id}) }}" class="text-slate-400 hover:text-amber-600 p-1.5 rounded-lg hover:bg-amber-50 transition" title="Modifier">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="5" class="py-8 text-center text-slate-400">
                                    Aucune donnée disponible.
                                </td>
                            </tr>
                        {% endfor %}

                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>
{% endblock %}