
{{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

<div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-4 sm:p-6 space-y-6">
    
    <div class="border-b border-gray-150 pb-3 flex justify-between items-center">
        <h2 class="text-sm font-bold text-gray-900 uppercase tracking-wider">
            Informations du contact
        </h2>
        
        {% if show is defined and show %}
            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-700 border border-indigo-100">
                Liaison : {{ show.title }}
            </span>
        {% endif %}
    </div>

    {# ─── IDENTITÉ  ─── #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
            {{ form_label(form.first_name, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.first_name, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.first_name) }}
        </div>
        <div>
            {{ form_label(form.last_name, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.last_name, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.last_name) }}
        </div>
    </div>

    {# ─── STRUCTURE & RÔLE  ─── #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-gray-50 pt-4">
        <div>
            {{ form_label(form.company_name, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.company_name, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.company_name) }}
        </div>
        <div>
            {{ form_label(form.role, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.role, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.role) }}
        </div>
    </div>

    {# ─── COORDONNÉES  ─── #}
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 border-t border-gray-50 pt-4">
        <div>
            {{ form_label(form.email, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.email, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.email) }}
        </div>
        <div>
            {{ form_label(form.phone, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
            {{ form_widget(form.phone, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
            {{ form_errors(form.phone) }}
        </div>
    </div>

    {# ───  SPECTACLES RATTACHÉS ─── #}
    <div class="border-t border-gray-50 pt-4">
        {{ form_label(form.shows, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
        <div class="relative">
            
            {{ form_widget(form.shows, {'attr': {'class': 'tom-select w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800'}}) }}
        </div>
        <p class="text-[11px] text-gray-400 mt-1.5">
            <i class="fa-solid fa-circle-info mr-1"></i> Recherchez ou sélectionnez un ou plusieurs spectacles dans la liste.
        </p>
        {{ form_errors(form.shows) }}
    </div>

    {# ─── NOTES INTERNE ─── #}
    <div class="border-t border-gray-50 pt-4">
        {{ form_label(form.notes, null, {'label_attr': {'class': 'block text-xs font-bold text-gray-500 uppercase mb-2'}}) }}
        {{ form_widget(form.notes, {'attr': {'class': 'w-full bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 text-sm focus:bg-white focus:border-indigo-500 focus:ring-2 focus:ring-indigo-100 transition outline-none text-gray-800', 'rows': '3'}}) }}
        {{ form_errors(form.notes) }}
    </div>

    {# ─── ACTION SUBMIT R─── #}
    <div class="border-t border-gray-50 pt-4 flex flex-col-reverse sm:flex-row justify-between items-center gap-4">
        
        
        {% if show is defined and show %}
            <a href="{{ path('show_show', {'id': show.id}) }}" class="w-full sm:w-auto text-center text-xs font-semibold text-gray-500 hover:text-gray-700 transition py-2">
                Retour au spectacle
            </a>
        {% else %}
            <a href="{{ path('contact_index') }}" class="w-full sm:w-auto text-center text-xs font-semibold text-gray-500 hover:text-gray-700 transition py-2">
                Annuler
            </a>
        {% endif %}

        <button type="submit" class="w-full sm:w-auto justify-center bg-slate-900 text-white text-xs font-bold px-5 py-2.5 rounded-xl hover:bg-slate-800 transition shadow-sm inline-flex items-center gap-2">
            {{ button_label|default('Enregistrer le contact') }} <i class="fa-solid fa-arrow-right text-[10px]"></i>
        </button>
    </div>

</div>

{{ form_rest(form) }}
{{ form_end(form) }}