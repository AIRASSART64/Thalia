{% extends 'base.html.twig' %}

{% block title %}Espace SuperAdmin - Thalia{% endblock %}

{% block body %}
<div class="bg-gray-50 min-h-screen font-sans">


    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        
        {# Titre et Introduction #}
        <div class="mb-8">
            <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">Gestion des accès</h1>
            <p class="text-gray-500 mt-1">Activez ou révoquez l'accès des structures à la plateforme Thalia.</p>
        </div>

        {# Flash Messages (Style moderne) #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-6 p-4 rounded-xl border {% if label == 'success' %}bg-emerald-50 border-emerald-100 text-emerald-800{% else %}bg-amber-50 border-amber-100 text-amber-800{% endif %} text-sm shadow-sm flex items-center gap-3">
                    <span class="w-2 h-2 rounded-full {% if label == 'success' %}bg-emerald-500{% else %}bg-amber-500{% endif %}"></span>
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        {# Carte principale avec Tableau #}
        <div class="bg-white rounded-2xl border border-gray-100 shadow-xl overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-gray-50/50 border-b border-gray-100">
                            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Utilisateur</th>
                            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Structure</th>
                            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider">Statut</th>
                            <th class="px-6 py-4 text-xs font-semibold text-gray-400 uppercase tracking-wider text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-50">
                    {% for user in users %}
                        <tr class="hover:bg-gray-50/30 transition">
                            <td class="px-6 py-5">
                                <div class="flex flex-col">
                                    <span class="text-sm font-bold text-gray-900">{{ user.lastName|upper }} {{ user.firstName }}</span>
                                    <span class="text-xs text-gray-400">{{ user.email }}</span>
                                </div>
                            </td>
                            <td class="px-6 py-5">
                                <span class="text-sm text-gray-600">
                                    {% if user.organization %}
                                        <div class="flex items-center gap-2">
                                            <i class="fa-solid fa-building text-gray-300 text-xs"></i>
                                            {{ user.organization.name }}
                                        </div>
                                    {% else %}
                                        <span class="text-gray-300 italic">Aucune</span>
                                    {% endif %}
                                </span>
                            </td>
                            <td class="px-6 py-5">
                                {% if user.isActive %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-50 text-emerald-700 border border-emerald-100">
                                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-2"></span>
                                        Actif
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-amber-50 text-amber-700 border border-amber-100">
                                        <span class="w-1.5 h-1.5 rounded-full bg-amber-500 mr-2"></span>
                                        En attente
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-5 text-right">
                                {% if app.user and user.email == app.user.email %}
                                    <span class="text-[10px] font-bold text-gray-300 uppercase bg-gray-50 px-2 py-1 rounded">
                                        <i class="fa-solid fa-lock mr-1"></i> Mon Compte
                                    </span>
                                {% else %}
                                    <form action="{{ path('superadmin_user_toggle_active', {'id': user.id}) }}" method="POST" class="inline">
                                        {% if user.isActive %}
                                            <button class="text-xs font-semibold text-amber-600 bg-amber-50 px-4 py-2 rounded-lg hover:bg-amber-100 transition border border-amber-100">
                                                Désactiver
                                            </button>
                                        {% else %}
                                            <button class="text-xs font-semibold text-white bg-indigo-600 px-4 py-2 rounded-lg hover:bg-indigo-700 transition shadow-sm shadow-indigo-100">
                                                Activer le compte
                                            </button>
                                        {% endif %}
                                    </form>
                                {% endif %}
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-6 py-12 text-center text-gray-400 italic">
                                Aucun utilisateur trouvé dans la base.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </main>

</div>
{% endblock %}
