{% extends 'base.html.twig' %}

{% block title %}Réinitialiser votre mot de passe - Thalia{% endblock %}

{% block body %}

<div class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4 overflow-y-auto font-sans">
    

    <div class="bg-white w-full max-w-md rounded-2xl shadow-2xl border border-slate-100 p-8 relative">
        
   
        <div class="text-center mb-6">
            <h1 class="text-xl font-bold text-slate-900 tracking-tight">Mot de passe oublié</h1>
            <p class="text-xs text-slate-400 mt-1">Saisissez votre e-mail pour recevoir un lien de récupération sécurisé.</p>
        </div>

        {% for flash_error in app.flashes('reset_password_error') %}
            <div class="mb-4 p-3 rounded-xl text-xs font-medium border bg-rose-50 border-rose-100 text-rose-700" role="alert">
                {{ flash_error }}
            </div>
        {% endfor %}

   
        {{ form_start(requestForm, {'attr': {'class': 'space-y-4', 'novalidate': 'novalidate'}}) }}
            
          
            <div>
                <label for="{{ requestForm.email.vars.id }}" class="block text-xs font-bold text-slate-700 mb-1">
                    Adresse e-mail professionnelle
                </label>
                {{ form_widget(requestForm.email, {
                    'attr': {
                        'class': 'w-full px-3 py-2.5 bg-slate-50/50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 transition placeholder-slate-300',
                        'placeholder': 'nom@institution.fr'
                    }
                }) }}
                {{ form_errors(requestForm.email, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
            </div>

           
            <div class="bg-slate-50 p-3 rounded-xl border border-slate-100/80">
                <p class="text-[11px] text-slate-500 leading-relaxed">
                    <i class="fa-solid fa-circle-info text-blue-500 mr-1"></i>
                    Après vérification, vous recevrez un lien unique et temporaire pour réinitialiser le mot de passe.
                </p>
            </div>

         
            <div class="pt-2">
                <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2.5 rounded-xl text-sm transition shadow-sm shadow-blue-100">
                    Envoyer 
                </button>
            </div>
            
            
            <div class="text-center pt-4 border-t border-slate-50 mt-4">
                <a href="{{ path('app_login') }}" class="text-xs text-blue-500 font-semibold hover:underline flex items-center justify-center gap-1.5">
                    <i class="fa-solid fa-arrow-left text-[10px]"></i> Retour à la connexion
                </a>
            </div>

        {{ form_end(requestForm) }}
    </div>
</div>
{% endblock %}
