{% extends 'base.html.twig' %}

{% block title %}Nouveau mot de passe - Thalia{% endblock %}

{% block body %}

<div class="fixed inset-0 z-50 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center p-4 overflow-y-auto font-sans">
    
   
    <div class="bg-white w-full max-w-md rounded-2xl shadow-2xl border border-slate-100 p-8 relative">
        
        <div class="text-center mb-6">
            <h1 class="text-xl font-bold text-slate-900 tracking-tight">Nouveau mot de passe</h1>
            <p class="text-xs text-slate-400 mt-1">Définissez votre nouveau mot de passe d'accès sécurisé.</p>
        </div>

        {{ form_start(resetForm, {'attr': {'class': 'space-y-4', 'novalidate': 'novalidate'}}) }}
            
       
            <div>
                <label for="{{ resetForm.plainPassword.first.vars.id }}" class="block text-xs font-bold text-slate-700 mb-1">
                    Nouveau mot de passe
                </label>
                {{ form_widget(resetForm.plainPassword.first, {
                    'attr': {
                        'class': 'w-full px-3 py-2 bg-slate-50/50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 transition',
                        'placeholder': '••••••••'
                    }
                }) }}
                {{ form_errors(resetForm.plainPassword.first, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
            </div>

        
            <div>
                <label for="{{ resetForm.plainPassword.second.vars.id }}" class="block text-xs font-bold text-slate-700 mb-1">
                    Confirmer le mot de passe
                </label>
                {{ form_widget(resetForm.plainPassword.second, {
                    'attr': {
                        'class': 'w-full px-3 py-2 bg-slate-50/50 border border-slate-200 rounded-xl text-sm focus:outline-none focus:border-blue-500 focus:bg-white focus:ring-1 focus:ring-blue-500 transition',
                        'placeholder': '••••••••'
                    }
                }) }}
                {{ form_errors(resetForm.plainPassword.second, {'attr': {'class': 'text-rose-500 text-xs mt-1'}}) }}
            </div>

         
            <div class="pt-2">
                <button type="submit" class="w-full bg-blue-500 hover:bg-blue-600 text-white font-semibold py-2.5 rounded-xl text-sm transition shadow-sm shadow-blue-100">
                    Réinitialiser mon mot de passe
                </button>
            </div>

        {{ form_end(resetForm) }}
    </div>
</div>
{% endblock %}
