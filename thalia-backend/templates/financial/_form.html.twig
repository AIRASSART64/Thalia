{{ form_start(form, {'attr': {'class': 'space-y-6'}}) }}

    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        {# Catégorie (Recette / Dépense) #}
        <div class="space-y-2">
            {{ form_label(form.category, 'Catégorie financière', {'label_attr': {'class': 'block text-xs font-bold text-slate-700 uppercase tracking-wider'}}) }}
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                    <i class="fa-solid fa-layer-group text-sm"></i>
                </div>
                {{ form_widget(form.category, {'attr': {
                    'class': 'w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 focus:border-sky-500 focus:bg-white focus:ring-2 focus:ring-sky-500/20 rounded-xl text-xs font-semibold text-slate-800 transition shadow-sm outline-none'
                }}) }}
            </div>
            {% if form.category.vars.errors|length > 0 %}
                <p class="text-xs text-rose-500 font-medium mt-1 flex items-center gap-1">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    {{ form_errors(form.category) }}
                </p>
            {% endif %}
        </div>

        {# Type (Sous-type de ligne budgétaire) #}
        <div class="space-y-2">
            {{ form_label(form.type, 'Type de transaction', {'label_attr': {'class': 'block text-xs font-bold text-slate-700 uppercase tracking-wider'}}) }}
            <div class="relative">
                <div class="absolute inset-y-0 left-0 pl-3.5 flex items-center pointer-events-none text-slate-400">
                    <i class="fa-solid fa-tag text-sm"></i>
                </div>
                {{ form_widget(form.type, {'attr': {
                    'class': 'w-full pl-10 pr-4 py-2.5 bg-slate-50 border border-slate-200 focus:border-sky-500 focus:bg-white focus:ring-2 focus:ring-sky-500/20 rounded-xl text-xs font-semibold text-slate-800 transition shadow-sm outline-none'
                }}) }}
            </div>
            {% if form.type.vars.errors|length > 0 %}
                <p class="text-xs text-rose-500 font-medium mt-1 flex items-center gap-1">
                    <i class="fa-solid fa-circle-exclamation"></i>
                    {{ form_errors(form.type) }}
                </p>
            {% endif %}
        </div>

    </div>

    {# Description / Notes #}
    <div class="space-y-2">
        {{ form_label(form.description, 'Description ou motif', {'label_attr': {'class': 'block text-xs font-bold text-slate-700 uppercase tracking-wider'}}) }}
        {{ form_widget(form.description, {'attr': {
            'rows': 4,
            'placeholder': 'Précisez l\'objet de cette ligne budgétaire (ex: Acompte cachets, Subvention DRAC, Achat matériel son...)',
            'class': 'w-full p-4 bg-slate-50 border border-slate-200 focus:border-sky-500 focus:bg-white focus:ring-2 focus:ring-sky-500/20 rounded-xl text-xs font-medium text-slate-800 placeholder-slate-400 transition shadow-sm outline-none'
        }}) }}
        {% if form.description.vars.errors|length > 0 %}
            <p class="text-xs text-rose-500 font-medium mt-1 flex items-center gap-1">
                <i class="fa-solid fa-circle-exclamation"></i>
                {{ form_errors(form.description) }}
            </p>
        {% endif %}
    </div>

    {# Actions du formulaire #}
    <div class="flex items-center justify-end gap-3 pt-4 border-t border-slate-100">
        <a href="{{ path('financial_index') }}" class="px-5 py-2.5 rounded-xl border border-slate-200 hover:bg-slate-50 text-slate-600 font-semibold text-xs transition">
            Annuler
        </a>
        <button type="submit" class="inline-flex items-center gap-2 px-6 py-2.5 rounded-xl bg-sky-500 hover:bg-sky-600 text-white font-semibold text-xs shadow-md shadow-sky-500/20 transition">
            <i class="fa-solid fa-check text-xs"></i>
            {{ button_label|default('Enregistrer') }}
        </button>
    </div>

{{ form_end(form) }}